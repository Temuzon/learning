{
  "name": "Habit",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the habit"
    },
    "purpose": {
      "type": "string",
      "description": "Why this habit matters \u2014 mandatory"
    },
    "benefit": {
      "type": "string",
      "description": "What benefit this habit provides"
    },
    "frequency": {
      "type": "string",
      "enum": [
        "daily",
        "weekdays",
        "weekends",
        "custom"
      ],
      "default": "daily",
      "description": "How often this habit repeats"
    },
    "custom_days": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "description": "Custom days of week (0=Sun, 6=Sat)"
    },
    "priority": {
      "type": "string",
      "enum": [
        "critical",
        "high",
        "medium",
        "low"
      ],
      "default": "medium"
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "trivial",
        "easy",
        "moderate",
        "hard",
        "extreme"
      ],
      "default": "moderate"
    },
    "schedule_time": {
      "type": "string",
      "description": "Optional preferred time"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "purpose"
  ]
}
